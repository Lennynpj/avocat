# ============================================================
#  Cabinet NGANGA — variables d'environnement
#  Copier ce fichier en .env.local puis remplir au besoin.
#  Tout peut rester VIDE en local : l'app simule alors
#  les paiements (Stripe) et logge emails/SMS dans la console.
# ============================================================

# Fuseau horaire — IMPORTANT pour le calcul des créneaux
TZ=Europe/Paris

# URL publique du site (sert aux redirections Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Espace admin (page de gestion) ---
ADMIN_PASSWORD=cabinet93
SESSION_SECRET=remplacer-par-une-longue-chaine-aleatoire

# --- Base de données ---
# Si MONGODB_URI est défini, l'app utilise MongoDB ; sinon le fichier data/db.json (POC).
MONGODB_URI=
MONGODB_DB=cabinet_nganga

# --- Stripe (laisser VIDE pour simuler les paiements en local) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend / email (laisser VIDE pour logguer dans la console) ---
RESEND_API_KEY=
EMAIL_FROM=Cabinet NGANGA <onboarding@resend.dev>

# --- SMS smsmode (Phase 1 — laisser VIDE pour simuler) ---
SMSMODE_API_KEY=
SMS_SENDER=CabinetAv

# --- Cron rappels 24h (protège l'endpoint) ---
CRON_SECRET=
